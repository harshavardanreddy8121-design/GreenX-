# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND — set these in Vercel dashboard under Project → Settings → Env Vars
# ─────────────────────────────────────────────────────────────────────────────
# Base URL of the deployed Java backend (NO trailing slash, NO /api suffix).
# Leave empty for local dev — Vite proxy forwards /api → localhost:8082.
# Render backend example: VITE_API_URL=https://greenx-backend-yyti.onrender.com
# Elastic Beanstalk example: VITE_API_URL=https://Greenx-env.eba-dyitamdp.us-east-1.elasticbeanstalk.com
# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — set these in Railway / Render dashboard as environment variables
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (AWS RDS or Elastic Beanstalk RDS)
# If you expose DB_HOST / DB_PORT / DB_NAME / DB_USER / DB_PASSWORD, the app will build the JDBC URL automatically.
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_RDS_HOST:5432/postgres
SPRING_DATASOURCE_USERNAME=Greenx_db
SPRING_DATASOURCE_PASSWORD=your_db_password
DB_HOST=YOUR_RDS_HOST
DB_PORT=5432
DB_NAME=postgres
DB_USER=Greenx_db
DB_PASSWORD=your_db_password

# JWT — use a long random secret in production (min 32 chars)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# CORS — comma-separated list of allowed frontend origins
# After deploying to Vercel, set this to your Vercel URL
ALLOWED_ORIGINS=https://web-hug-studio-46-043df96f-70335c46-main.vercel.app

# Port — Railway sets this automatically; leave unset on Render
# PORT=8082
