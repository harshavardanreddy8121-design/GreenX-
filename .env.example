# Frontend Configuration for Java Backend + Oracle Database
# ─────────────────────────────────────────────────────────────────────────────
# VITE_API_URL  — base URL of the deployed Java backend (NO trailing slash,
#                 NO /api suffix).  Leave empty for local dev (Vite proxy works).
#
# Examples:
#   Railway  → VITE_API_URL=https://greenx-api.up.railway.app
#   Render   → VITE_API_URL=https://greenx-api.onrender.com
#   Local    → VITE_API_URL=          (empty — Vite proxy to localhost:8082)
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_URL=
