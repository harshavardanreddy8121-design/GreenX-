# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND — set these in Vercel dashboard under Project → Settings → Env Vars
# ─────────────────────────────────────────────────────────────────────────────
# Base URL of the deployed Java backend (NO trailing slash, NO /api suffix).
# The frontend automatically appends /api to this value.
#
# LOCAL DEV: leave VITE_API_URL empty (commented out or unset).
#   Vite proxy will forward /api requests → http://localhost:8080 automatically.
#   Setting VITE_API_URL in local dev will bypass the proxy and cause CORS errors
#   if the remote backend doesn't allow localhost origins.
#
# PRODUCTION (Vercel): set to your Render backend URL, e.g.:
#   VITE_API_URL=https://greenx-backend-yyti.onrender.com
#
# Uncomment and fill in only when deploying to Vercel:
# VITE_API_URL=
# ─────────────────────────────────────────────────────────────────────────────
# BACKEND — set these in the Render dashboard (Service → Environment)
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (AWS RDS)
# Set the full JDBC connection URL, username, and password for your AWS RDS instance.
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_RDS_HOST:5432/postgres
SPRING_DATASOURCE_USERNAME=Greenx_db
SPRING_DATASOURCE_PASSWORD=your_db_password

# JWT — use a long random secret in production (min 32 chars)
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# CORS — comma-separated list of allowed frontend origins (your Vercel URLs)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Port — Render injects this automatically; leave unset on Render
# PORT=8080
